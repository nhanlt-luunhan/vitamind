NEXT_PUBLIC_APP_URL=https://app.vitamind.com.vn
SITE_URL=https://app.vitamind.com.vn

APP_BIND_IP=0.0.0.0
APP_PORT=3333

POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=vitamind
POSTGRES_USER=vitamind
POSTGRES_PASSWORD=change-me-postgres

PGADMIN_BIND_IP=127.0.0.1
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@vitamind.com.vn
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin

# Required: generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

INTERNAL_API_SECRET=change-me
INTERNAL_API_BASE_URL=https://app.vitamind.com.vn

# Google OAuth – required for Google login to work
# Set NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true after filling in ID and SECRET
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match exactly what is registered in Google Cloud Console > Credentials > Authorized redirect URIs
GOOGLE_OAUTH_REDIRECT_URI=https://app.vitamind.com.vn/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

ALLOW_EMAILS=
