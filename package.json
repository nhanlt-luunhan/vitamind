{
  "name": "vitamind",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3333",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3333",
    "clerk:sync": "node ./scripts/clerk-sync.mjs",
    "db:sync": "node ./scripts/sync-db.mjs",
    "db:sync:docker": "node ./scripts/sync-db.mjs --mode docker",
    "db:sync:url": "node ./scripts/sync-db.mjs --mode url",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.3",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.3",
    "next": "^16.1.6",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swiper": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
