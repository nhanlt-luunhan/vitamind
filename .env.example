SITE_URL=http://localhost:3333

# Database cho local/dev
# Khong tro local vao DB production.
DATABASE_URL=postgresql://vitamind:vitamind@127.0.0.1:33542/vitamind

# Clerk auth
# Co the dung chung Clerk voi production neu muon dev/prod dung cung tap user.
# Neu dung chung Clerk, van phai giu DATABASE_URL rieng cho local/dev.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_pk_test_CHANGE_ME
CLERK_SECRET_KEY=sk_live_or_sk_test_CHANGE_ME
CLERK_WEBHOOK_SIGNING_SECRET=whsec_CHANGE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/continue
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/continue
SHARED_CLERK_MODE=false
PROTECT_SHARED_IDENTITY_FIELDS=true

# Internal
INTERNAL_API_SECRET=change-me
INTERNAL_API_BASE_URL=http://127.0.0.1:3333
PGADMIN_DEFAULT_EMAIL=admin@vitamind.com.vn
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin
PGADMIN_BIND_IP=127.0.0.1
PGADMIN_PORT=35050

# Optional
ALLOW_EMAILS=
